{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write(internal/**)",
      "Write(cmd/**)",
      "Write(docs/**)",
      "Write(.claude/**)",
      "Write(.github/**)",
      "Write(*.md)",
      "Write(*.go)",
      "Write(Makefile)",
      "Write(.goreleaser.yml)",
      "Write(go.mod)",
      "Write(go.sum)",
      "Bash(go:*)",
      "Bash(golangci-lint:*)",
      "Bash(make:*)",
      "Bash(./bin/nylas:*)",
      "Bash(~/go/bin/goreleaser:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git show:*)",
      "Bash(git pull:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(rm *.test:*)",
      "Bash(rm ./bin/*:*)",
      "Bash(rm -f ./bin/*:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(pwd)",
      "Bash(curl:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(gh:*)",
      "WebSearch",
      "WebFetch(domain:developer.nylas.com)",
      "WebFetch(domain:cli.nylas.com)",
      "WebFetch(domain:dev.to)",
      "WebFetch(domain:www.anthropic.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:github.com/anthropics)",
      "WebFetch(domain:code.claude.com)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --hard)",
      "Bash(git clean:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(rm -rf /*)",
      "Bash(rm -r /)",
      "Bash(rm -r ~)",
      "Bash(rm -r .)",
      "Bash(sudo rm -rf:*)",
      "Bash(truncate:*)",
      "Bash(wget:*)",
      "Bash(chmod 777:*)",
      "Bash(eval:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/credentials.json)",
      "Read(**/credentials.yaml)",
      "Read(**/credentials.yml)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/secrets/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q 'git commit'; then (git diff --cached --name-only | grep -E '\\.(env|pem|key|p12)$' || git diff --cached | grep -iE '(api_key|password|secret|token|nyk_v0)') && echo '⛔ BLOCKED: Sensitive content in commit' && exit 2 || exit 0; fi"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/file-size-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh"
          }
        ]
      }
    ]
  }
}
